#!/usr/bin/env bash
#set -x
# ---- |EXT ----
VARSET_EXT=$1
# ---- |DEFAULT ----
DKR_IMAGE=localstack/localstack
# ---- |OVERRIDE ----
source .properd/VARSET
test -n "$VARSET_EXT" && source $VARSET_EXT

# ---- |MAIN ----
docker run   \
    --rm \
    -it \
    -p 4566:4566 \
    -p 4510-4559:4510-4559 \
    -e LOCALSTACK_API_KEY=${LOCALSTACK_API_KEY:- } \
    $DKR_IMAGE
